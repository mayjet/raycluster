# Tailscale Auth Key (from https://login.tailscale.com/admin/settings/keys)
TAILSCALE_AUTHKEY=tskey-auth-XXXXXXXXXX

# Consul settings
CONSUL_BOOTSTRAP_EXPECT=2

# Consul retry join - use Tailscale hostnames or IPs
# Format: -retry-join=<tailscale-hostname-1> -retry-join=<tailscale-hostname-2>
CONSUL_RETRY_JOIN=-retry-join=consul-lyon002 -retry-join=consul-lyon004

# Hostname for this VM
HOSTNAME=lyon002
